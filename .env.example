# PostgreSQL 连接地址
DATABASE_URL=postgresql://app:app@localhost:5432/happy_agent

# Redis 连接地址
REDIS_URL=redis://localhost:6379/0

# OpenAI API Key（可留空）
OPENAI_API_KEY=

# OpenAI 兼容服务地址（可留空）
OPENAI_BASE_URL=

# Embedding 模型
OPENAI_EMBED_MODEL=text-embedding-3-small

# 对话模型
OPENAI_CHAT_MODEL=gpt-4.1-mini

# 后端监听地址
API_HOST=0.0.0.0

# 后端端口
API_PORT=8000

# 前端来源（CORS）
FRONTEND_ORIGIN=http://localhost:3000
